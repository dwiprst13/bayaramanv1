        "wallet.withdraw",

        "kyc.submit"
      ]
    },
    {
      "name": "verified_seller",
      "description": "Seller terpercaya dengan privilege tambahan",
      "permissions": [
        "profile.read",
        "profile.update",

        "transaction.read_own",
        "transaction.ship",

        "evidence.upload",

        "dispute.read_own",
        "dispute.reply",

