      "permissions": [
        "*"
      ]
    },
    {
      "name": "admin",
      "description": "Mengelola operasional escrow",
      "permissions": [
        "user.read",
        "user.suspend",
        "user.verify",

        "transaction.read",
        "transaction.update",
        "transaction.freeze",
        "transaction.release",

        "dispute.read",
        "dispute.resolve",

        "kyc.read",
        "kyc.verify",

        "wallet.read",
        "wallet.adjust",

        "audit.read"
      ]
    },
    {
      "name": "fraud_analyst",
      "description": "Menganalisis fraud dan aktivitas mencurigakan",
      "permissions": [
        "user.read",
        "transaction.read",
        "transaction.freeze",

        "dispute.read",

        "kyc.read",

        "wallet.read",

        "audit.read",
        "risk.read",
        "risk.update"
      ]
    },
    {
